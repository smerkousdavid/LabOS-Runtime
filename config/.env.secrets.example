# LabOS Secrets -- fill in keys as needed.
# Copy to .env.secrets:  cp .env.secrets.example .env.secrets

# NVIDIA NGC (only needed if running NIM-based STT/TTS locally)
NGC_API_KEY=

# HuggingFace (only needed if running gated models locally)
HF_TOKEN=

# SerpAPI (for agent web search -- optional, falls back to DuckDuckGo)
SERPAPI_KEY=

# Alibaba DashScope (only for Qwen TTS provider)
DASHSCOPE_API_KEY=

# ElevenLabs (for STT Scribe and TTS)
ELEVENLABS_API_KEY=
