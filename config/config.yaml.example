# =============================================================================
# LabOS XR Runtime -- Desktop Application Configuration (Example)
#
# Copy this file to config.yaml and edit for your environment:
#   cp config.yaml.example config.yaml
# =============================================================================

# NAT Server -- external agent server connection
nat_server:
  url: "ws://192.168.1.100:8002/ws"      # Set to your NAT server's address

# XR Runtime
runtime:
  num_cameras: 1
  streaming:
    method: mediamtx
    framerate: 30
    mediamtx_port: 8554
    mediamtx_service_name: mediamtx

# Speech services (external endpoints)
speech:
  stt:
    host: "192.168.1.100"                 # Your STT server
    port: 50051
    protocol: elevenlabs_realtime
    model: "scribe_v2_realtime"
    language: "en"
    commit_interval_s: 0.25
    min_speech_duration_ms: 500
    min_silence_duration_ms: 500
    include_timestamps: true
    fallback_recover_after_s: 30
    fallback:
      protocol: grpc
      host: "192.168.1.100"
      port: 50051
      model: "parakeet-1.1b-en-US-asr-streaming"
    noise_correction:
      enabled: true
      gate_rms: 120
      suppression_terms: [mhm, mm, mmm, hmm, hm, uh, um, ah, oh, uh-huh, mm-hmm, "mhm mhm", "so so", he, ha, hey, hi]
      spam_guard_window_s: 1.0
  tts:
    enabled: true
    provider: vibevoice
    vibevoice:
      host: "192.168.1.100"              # Your TTS server
      port: 8050

# Dashboard
dashboard:
  port: 5001

# NVR (optional)
nvr:
  enabled: false

# Wake word
wakeword:
  words: [stella, hey stella]
  timeout_seconds: 10
  sleep_commands: [thanks, goodbye, go to sleep]

# Global
global:
  secrets_file: config/.env.secrets
