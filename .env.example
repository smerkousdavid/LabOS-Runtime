# =============================================================================
# labos-runtime environment variables
# Generated by configure.py from architecture.yaml -- DO NOT EDIT MANUALLY.
# Copy this file to .env and adjust as needed.
# =============================================================================

# --- Runtime ---
NUM_CAMERAS=1
STREAMING_METHOD=mediamtx
DEFAULT_FRAMERATE=30
MEDIAMTX_SERVICE_NAME=mediamtx

# --- Ports ---
GRPC_PORT=5050
WEB_PORT=5001
NAT_PORT=8002
TTS_PUSHER_PORT=5100
TTS_MIXER_PORT=5004
NVR_PORT=8088

# --- NAT Server ---
NAT_SERVER_URL=ws://nat-server:8002/ws
NAT_HOST=0.0.0.0
VIDEO_MODE=websocket

# --- Video Relay (Mode 3 only) ---
RELAY_TARGET=rtsp://nat-server:8654
NAT_MEDIAMTX_PORT=8654

# --- Speech ---
STT_HOST=stt-service
STT_PORT=50051
STT_PROTOCOL=grpc
ENABLE_TTS=true
TTS_PROVIDER=riva

# --- TTS Provider Config ---
RIVA_HOST=riva-server
RIVA_PORT=50051
DASHSCOPE_API_KEY=your-api-key-here
ENABLE_RIVA_TTS=true
ENABLE_DASHSCOPE_TTS=false

# --- Language Models ---
LLM_BASE_URL=http://llm:8001/v1
LLM_MODEL=Qwen/Qwen3-32B-AWQ
VLM_BASE_URL=http://vlm:8500/v1
VLM_MODEL=Zaixi/STELLA-VLM-32b

# --- NVR (Shinobi) ---
ENABLE_NVR=true
MAIL=viture@test.com
PASSWORD=test1234
GROUP_KEY=KpM6j63XY7
UNIQUE_ID=8N8ngH8WUt
API_KEY=eTJceyxeZWnaGqUKx1Asw0u3m29frk
STORAGE_SIZE=300000

# --- Docker Images ---
RTSP_IMAGE=labos_streaming:latest

# --- Audio Forwarding ---
FORWARD_AUDIO=false
