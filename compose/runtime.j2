# Auto-generated by compose/generate.py -- do not edit manually.

x-logging: &default-logging
  driver: json-file
  options:
    max-size: "20m"
    max-file: "5"
    tag: "{% raw %}{{.Name}}{% endraw %}"

services:

  # ===========================================================================
  # MediaMTX -- Central RTSP relay
  # ===========================================================================
{% if streaming_method == 'mediamtx' %}
  {{ mediamtx_service_name }}:
    image: bluenviron/mediamtx:latest-ffmpeg
    container_name: {{ mediamtx_service_name }}
    restart: unless-stopped
    logging: *default-logging
    ports:
      - "8554:8554"
      - "8890:8888"
      - "8889:8889"
    volumes:
      - ./xr_runtime/streaming/mediamtx.yml:/mediamtx.yml
      - ./logs/mediamtx:/logs
{% endif %}

  # ===========================================================================
  # Per-camera services
  # ===========================================================================
{% for i in range(num_cameras) %}
  # --- Camera {{ i+1 }} ---
  grpc-server-{{ i+1 }}:
    image: python:3.12.6-slim
    platform: linux/amd64
    ports:
      - "{{ base_ports.GRPC_PORT + i }}:5050"
    volumes:
      - ./xr_runtime/grpc_server/main.bin:/home/gRPC_server/main.bin
      - xr_socket_{{ i+1 }}:/tmp
      - ./logs/grpc_{{ i+1 }}:/logs
    working_dir: /home/gRPC_server
    entrypoint: ["/home/gRPC_server/main.bin"]
    restart: unless-stopped
    logging: *default-logging
    container_name: labos_grpc_{{ i+1 }}
    ipc: "shareable"

{% if streaming_method == 'mediamtx' %}
  video-pusher-{{ i+1 }}:
    image: {{ rtsp_image }}
    volumes:
      - ./xr_runtime/streaming:/home/streaming
      - xr_socket_{{ i+1 }}:/tmp
      - ./logs/video_pusher_{{ i+1 }}:/logs
    working_dir: /home/streaming
    command: >
      poetry run python rtsp_pusher.py
      --socket-path /tmp/xr_service.sock
      --mediamtx-url rtsp://{{ mediamtx_service_name }}:8554/NB_{{ "%04d" | format(i+1) }}_TX_CAM_RGB
      --width 1280 --height 720 --framerate {{ default_framerate }}
    restart: unless-stopped
    logging: *default-logging
    container_name: labos_video_pusher_{{ i+1 }}
    environment:
      - LOGURU_LEVEL=ERROR
    depends_on:
      - grpc-server-{{ i+1 }}
      - {{ mediamtx_service_name }}

  audio-pusher-{{ i+1 }}:
    image: {{ rtsp_image }}
    volumes:
      - ./xr_runtime/streaming:/home/streaming
      - xr_socket_{{ i+1 }}:/tmp
      - ./logs/audio_pusher_{{ i+1 }}:/logs
    working_dir: /home/streaming
    command: >
      poetry run python audio_pusher.py
      --socket-path /tmp/xr_service.sock
      --audio-url rtsp://{{ mediamtx_service_name }}:8554/NB_{{ "%04d" | format(i+1) }}_TX_MIC_p6S
      --sample-rate 48000 --channels 1
    restart: unless-stopped
    logging: *default-logging
    container_name: labos_audio_pusher_{{ i+1 }}
    environment:
      - LOGURU_LEVEL=ERROR
    depends_on:
      - grpc-server-{{ i+1 }}
      - {{ mediamtx_service_name }}

  av-merger-{{ i+1 }}:
    image: {{ rtsp_image }}
    volumes:
      - ./xr_runtime/streaming:/home/streaming
      - ./logs/av_merger_{{ i+1 }}:/logs
    working_dir: /home/streaming
    command: >
      poetry run python av_merger.py
      --video-url rtsp://{{ mediamtx_service_name }}:8554/NB_{{ "%04d" | format(i+1) }}_TX_CAM_RGB
      --audio-url rtsp://{{ mediamtx_service_name }}:8554/NB_{{ "%04d" | format(i+1) }}_TX_MIC_p6S
      --output-url rtsp://{{ mediamtx_service_name }}:8554/NB_{{ "%04d" | format(i+1) }}_TX_CAM_RGB_MIC_p6S
    restart: unless-stopped
    logging: *default-logging
    container_name: labos_av_merger_{{ i+1 }}
    environment:
      - LOGURU_LEVEL=ERROR
    depends_on:
      - video-pusher-{{ i+1 }}
      - audio-pusher-{{ i+1 }}
      - {{ mediamtx_service_name }}
{% endif %}

  voice-bridge-{{ i+1 }}:
    build:
      context: ./xr_runtime
      dockerfile: voice_bridge/Dockerfile
    volumes:
      - xr_socket_{{ i+1 }}:/tmp
      - ./logs/voice_bridge_{{ i+1 }}:/app/logs
    environment:
      - NAT_SERVER_URL={{ nat_server_url }}
      - CAMERA_INDEX={{ i+1 }}
      - SESSION_ID=demo-{{ i+1 }}
      - MEDIAMTX_HOST={{ mediamtx_service_name }}
      - STT_HOST={{ stt_host }}
      - STT_PORT={{ stt_port }}
      - STT_PROTOCOL={{ stt_protocol }}
      - TTS_PUSHER_URL={{ tts_pusher_url }}
      - DASHBOARD_URL={{ dashboard_url }}
      - SOCKET_PATH=/tmp/xr_service.sock
      - FORWARD_AUDIO={{ forward_audio }}
      - TTS_MODEL={{ tts_model }}
      - LOGURU_LEVEL=INFO
    restart: unless-stopped
    logging: *default-logging
    container_name: labos_voice_bridge_{{ i+1 }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    depends_on:
      - grpc-server-{{ i+1 }}
{% if streaming_method == 'mediamtx' %}
      - {{ mediamtx_service_name }}
{% endif %}

{% endfor %}

  # ===========================================================================
  # Dashboard -- Web UI
  # ===========================================================================
  dashboard:
    build:
      context: ./xr_runtime
      dockerfile: dashboard/Dockerfile
    ports:
      - "5001:5000"
    volumes:
      - xr_socket_1:/tmp
      - ./logs/dashboard:/app/logs
    environment:
      - SOCKET_PATH=/tmp/xr_service.sock
      - NUM_CAMERAS={{ num_cameras }}
      - NAT_WS_URL={{ nat_ws_url }}
    command: ["python3", "server.py", "--num-cameras", "{{ num_cameras }}"]
    restart: always
    logging: *default-logging
    container_name: labos_dashboard
    extra_hosts:
      - "host.docker.internal:host-gateway"
    depends_on:
      - grpc-server-1

{% if ENABLE_TTS %}
  # ===========================================================================
  # TTS Pusher -- synthesis server
  # ===========================================================================
  tts-pusher:
    build:
      context: ./xr_runtime/speech/tts_pusher
      dockerfile: Dockerfile
    ports:
      - "5100:5000"
    volumes:
      - ./xr_runtime/speech/tts_pusher:/app
      - ./logs/tts_pusher:/app/logs
    working_dir: /app
    command: python3 tts_pusher.py --host 0.0.0.0 --port 5000
    restart: unless-stopped
    logging: *default-logging
    container_name: labos_tts_pusher
    env_file: .env
    environment:
      - LOGURU_LEVEL=INFO
      - TTS_MODELS_CONFIG=/app/tts_models.yaml
      - TTS_MIXER_URL=http://tts-mixer:5002
      - MEDIAMTX_SERVICE_NAME={{ mediamtx_service_name }}
    dns:
      - 8.8.8.8
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% if streaming_method == 'mediamtx' %}
    depends_on:
      - {{ mediamtx_service_name }}
{% endif %}

  # ===========================================================================
  # TTS Mixer -- persistent RTSP audio publisher
  # ===========================================================================
  tts-mixer:
    build:
      context: ./xr_runtime/speech/tts_mixer
      dockerfile: Dockerfile
    ports:
      - "5004:5002"
    volumes:
      - ./xr_runtime/speech/tts_mixer:/app
      - ./logs/tts_mixer:/app/logs
    working_dir: /app
    command: python3 tts_mixer.py --num-cameras {{ num_cameras }} --mediamtx-service-name {{ mediamtx_service_name }} --host 0.0.0.0 --port 5002
    restart: unless-stopped
    logging: *default-logging
    container_name: labos_tts_mixer
    dns:
      - 8.8.8.8
    env_file: .env
    environment:
      - MEDIAMTX_SERVICE_NAME={{ mediamtx_service_name }}
{% if streaming_method == 'mediamtx' %}
    depends_on:
      - {{ mediamtx_service_name }}
{% endif %}
{% endif %}

{% if ENABLE_NVR %}
  # ===========================================================================
  # NVR -- Shinobi
  # ===========================================================================
  db:
    container_name: labos_db
    image: mysql:8.0
    logging: *default-logging
    environment:
      MYSQL_ROOT_PASSWORD: r00t
      MYSQL_DATABASE: shinobi_dev
      MYSQL_USER: shinobi_dev_user
      MYSQL_PASSWORD: pass
    command: --default-authentication-plugin=mysql_native_password --skip-ssl
    volumes:
      - ./xr_runtime/nvr/mysql:/var/lib/mysql
      - ./xr_runtime/nvr/mysql-init:/docker-entrypoint-initdb.d
    ports:
      - "9906:3306"
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      timeout: 20s
      retries: 3

  shinobi:
    build: ./xr_runtime/nvr
    restart: always
    logging: *default-logging
    depends_on:
      db:
        condition: service_healthy
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - /etc/timezone:/etc/timezone:ro
      - ./xr_runtime/nvr/config:/config
      - ./xr_runtime/nvr/videos:/home/Shinobi/videos
      - /dev/shm/shinobiDockerTemp:/dev/shm/streams
    ports:
      - "8088:8080"
{% endif %}

# ===========================================================================
# Volumes
# ===========================================================================
volumes:
{% for i in range(num_cameras) %}
  xr_socket_{{ i+1 }}:
{% endfor %}
